# char type demo
char letter = 'H';
print letter;

char e = 'e';
print e;

char l = 'l';
print l;
print l;

char o = 'o';
print o;

print '\n';

# char with increment
char c = 'a';
c++;
c++;
print c;
print '\n';

# char with const
const char x = 'X';
print x;
print '\n';

# mixing char and int64
int64 code = 42;
print code;
print '\n';

exit 0;
