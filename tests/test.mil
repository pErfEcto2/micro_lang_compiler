# do/while: always runs body at least once
int64 i = 0;
do {
  print i;
  print '\n';
  i++;
} while (i < 5);

# runs once even when condition is false
int64 x = 42;
do {
  print x;
  print '\n';
} while (0);

# do/while with postfix in condition
int64 n = 0;
do {
  print n;
} while (n++ < 3);
print '\n';
