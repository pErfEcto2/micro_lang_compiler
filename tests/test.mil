# TRUE/FALSE boolean constants
int64 x = 5;

if (x > 0 == TRUE) {
  print 'y';
}

if (x > 0 == FALSE) {
  print 'n';
}

# boolean arithmetic
int64 sum = TRUE + TRUE + FALSE;
print sum;

# subtraction without spaces
int64 a = 10-3-2;
print a;

# nested bare blocks
int64 count = 0;
while (count < 3) {
  int64 tmp = count;
  {
    count = count + 1;
  }
}
print count;

print '\n';
